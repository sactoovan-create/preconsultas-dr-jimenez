# Variables de entorno de la aplicación.
#
# Cópialo a ".env.local" para desarrollo, o configúralas en el panel del hosting
# (Vercel) para producción. NUNCA subas tus claves reales al repositorio.
#
# Sin estas variables, la app funciona en modo local de prueba (las respuestas se
# guardan solo en el navegador). Con ellas, se conecta a la base de datos del
# consultorio y las respuestas llegan desde cualquier dispositivo.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANONIMA_PUBLICA
